<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="E. Sociales" />
  <meta name="theme-color" content="#9B72CF" />
  <meta name="description" content="App educativa de Estudios Sociales para primer grado" />
  <meta name="mobile-web-app-capable" content="yes" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/icon-192x192.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192x192.png" />
  <title>Estudios Sociales - Primer Grado</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body, #root { height: 100%; }
    body {
      font-family: 'Nunito', sans-serif;
      background: #FFF8F0;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overscroll-behavior-y: contain;
      -webkit-tap-highlight-color: transparent;
      padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
    @keyframes popIn { 0% { transform: scale(0.5); opacity: 0; } 70% { transform: scale(1.1); } 100% { transform: scale(1); opacity: 1; } }
    @keyframes fadeInOut { 0% { opacity: 0; } 20% { opacity: 1; } 80% { opacity: 1; } 100% { opacity: 0; } }
    button:active { transform: translateY(0) scale(0.97) !important; box-shadow: none !important; }
    /* Splash / loading */
    #splash {
      position: fixed; inset: 0; background: #FFF8F0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      z-index: 9999; transition: opacity 0.4s ease;
    }
    #splash.hide { opacity: 0; pointer-events: none; }
    #splash .emoji { font-size: 80px; animation: float 2s ease-in-out infinite; }
    #splash .title { font-size: 24px; font-weight: 900; color: #9B72CF; margin-top: 12px; }
    #splash .sub { font-size: 15px; color: #B2BEC3; margin-top: 6px; }
    #splash .dots { margin-top: 20px; display: flex; gap: 8px; }
    #splash .dots span {
      width: 10px; height: 10px; border-radius: 50%; background: #9B72CF;
      animation: dotPulse 1.2s infinite ease-in-out;
    }
    #splash .dots span:nth-child(2) { animation-delay: 0.2s; }
    #splash .dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes dotPulse { 0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); } 40% { opacity: 1; transform: scale(1.2); } }
    /* Install banner */
    .install-banner {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 1500;
      background: white; padding: 16px 20px; box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
      display: flex; align-items: center; gap: 14; border-radius: 20px 20px 0 0;
      animation: slideUp 0.3s ease;
    }
    @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
  </style>
</head>
<body>

<!-- Splash screen -->
<div id="splash">
  <div class="emoji">📚</div>
  <div class="title">Estudios Sociales</div>
  <div class="sub">Cargando...</div>
  <div class="dots"><span></span><span></span><span></span></div>
</div>

<div id="root"></div>

<!-- React 18 production -->
<script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>

<script>
// ─── Persistence helper ───
const Storage = {
  get(key, fallback) {
    try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : fallback; }
    catch { return fallback; }
  },
  set(key, val) {
    try { localStorage.setItem(key, JSON.stringify(val)); } catch {}
  }
};

// ─── Service worker registration ───
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./sw.js').then(
      (reg) => console.log('SW registered:', reg.scope),
      (err) => console.log('SW failed:', err)
    );
  });
}

// ─── PWA Install prompt ───
let deferredPrompt = null;
window.addEventListener('beforeinstallprompt', (e) => {
  e.preventDefault();
  deferredPrompt = e;
  // Show custom install UI after app loads
  setTimeout(() => {
    if (deferredPrompt && window.__showInstallBanner) window.__showInstallBanner();
  }, 3000);
});
</script>

<script>
const { useState, useCallback, useRef, useEffect, createElement: h, Fragment } = React;

/* ───────── palette ───────── */
const C = {
  bg:"#FFF8F0",pink:"#FF6B9D",orange:"#FF9A56",yellow:"#FFD93D",green:"#6BCB77",
  blue:"#4D96FF",purple:"#9B72CF",red:"#FF6B6B",dark:"#2D3436",white:"#FFFFFF",
  gray:"#B2BEC3",shadow:"0 8px 32px rgba(0,0,0,0.12)",shadowSm:"0 4px 12px rgba(0,0,0,0.08)"
};
const STAR="⭐",CHECK="✅",WRONG="❌",PARTY="🎉";
const ACTIVITIES=[
  {name:"Estudios Sociales",emoji:"📚",color:C.purple,desc:"¿Qué temas estudia esta materia?"},
  {name:"Historia Personal",emoji:"👶",color:C.orange,desc:"Ordená los eventos de tu vida"},
  {name:"Vivir en Sociedad",emoji:"🏘️",color:C.green,desc:"¿Qué nos ayuda a convivir?"},
  {name:"Árbol Genealógico",emoji:"🌳",color:C.blue,desc:"Identificá a los miembros de la familia"},
  {name:"Derechos y Deberes",emoji:"⚖️",color:C.pink,desc:"¿Derecho o deber?"},
];

/* ───────── helpers ───────── */
function s(tag, props, ...kids) { return h(tag, props, ...kids); }

/* ───────── Components ───────── */
function Btn({children,color=C.blue,onClick,big,disabled,style:st}) {
  return h('button',{onClick,disabled,style:{
    background:disabled?C.gray:color,color:C.white,border:'none',
    borderRadius:big?24:18,padding:big?'20px 40px':'14px 28px',
    fontSize:big?26:20,fontWeight:700,fontFamily:"'Nunito',sans-serif",
    cursor:disabled?'default':'pointer',
    boxShadow:disabled?'none':`0 6px 0 ${color}88, ${C.shadowSm}`,
    transform:disabled?'none':'translateY(-2px)',transition:'all 0.15s ease',
    touchAction:'manipulation',WebkitTapHighlightColor:'transparent',minHeight:56,
    ...st
  }},children);
}

function Card({children,color=C.white,style:st,onClick}) {
  return h('div',{onClick,style:{
    background:color,borderRadius:24,padding:20,boxShadow:C.shadowSm,
    transition:'all 0.2s ease',cursor:onClick?'pointer':'default',
    touchAction:'manipulation',...st
  }},children);
}

function ProgressBar({current,total,color=C.green}) {
  const pct=Math.round((current/total)*100);
  return h('div',{style:{width:'100%',background:'#e0e0e0',borderRadius:20,height:18,overflow:'hidden'}},
    h('div',{style:{width:`${pct}%`,background:`linear-gradient(90deg,${color},${color}cc)`,height:'100%',borderRadius:20,transition:'width 0.5s ease'}})
  );
}

function StarBurst({show}) {
  if(!show) return null;
  return h('div',{style:{position:'fixed',inset:0,display:'flex',alignItems:'center',justifyContent:'center',zIndex:1000,pointerEvents:'none',animation:'fadeInOut 1.5s ease forwards'}},
    h('div',{style:{fontSize:100,animation:'popIn 0.5s ease'}},PARTY)
  );
}

function FeedbackBubble({correct,message}) {
  return h('div',{style:{
    padding:'14px 24px',borderRadius:20,background:correct?'#d4edda':'#f8d7da',
    border:`3px solid ${correct?C.green:C.red}`,fontSize:20,fontWeight:700,
    textAlign:'center',fontFamily:"'Nunito',sans-serif",
    color:correct?'#155724':'#721c24',animation:'popIn 0.3s ease',marginTop:12
  }},correct?CHECK:WRONG,' ',message);
}

function StarsDisplay({count}) {
  if(count===0) return h('span',{style:{fontSize:14,color:C.gray,fontWeight:600}},'Sin jugar');
  return h('span',{style:{fontSize:18}},STAR.repeat(count)+'☆'.repeat(3-count));
}

/* ───────── ACTIVITY 1 ───────── */
const ACT1_ITEMS=[
  {text:"Las normas para una buena convivencia",correct:true,emoji:"🤝"},
  {text:"El sonido de las letras",correct:false,emoji:"🔤"},
  {text:"Los números y las sumas",correct:false,emoji:"🔢"},
  {text:"Los rasgos de la comunidad",correct:true,emoji:"🏘️"},
  {text:"La historia de la comunidad",correct:true,emoji:"📜"},
  {text:"El ciclo de vida de los animales",correct:false,emoji:"🐛"},
  {text:"Las familias y la sociedad",correct:true,emoji:"👨‍👩‍👧‍👦"},
  {text:"Las plantas y la fotosíntesis",correct:false,emoji:"🌱"},
];

function Activity1({onFinish}) {
  const [selected,setSelected]=useState(new Set());
  const [submitted,setSubmitted]=useState(false);
  const [score,setScore]=useState(0);
  const toggle=i=>{if(submitted)return;setSelected(p=>{const n=new Set(p);n.has(i)?n.delete(i):n.add(i);return n;});};
  const check=()=>{let s=0;ACT1_ITEMS.forEach((item,i)=>{if((item.correct&&selected.has(i))||(!item.correct&&!selected.has(i)))s++;});setScore(s);setSubmitted(true);};
  const total=ACT1_ITEMS.length;
  const stars=score>=total?3:score>=total-2?2:score>=total-4?1:0;

  return h('div',null,
    h('h2',{style:{fontSize:26,color:C.purple,textAlign:'center',margin:'0 0 8px'}},'📚 ¿Qué estudia Estudios Sociales?'),
    h('p',{style:{fontSize:18,textAlign:'center',color:C.dark,margin:'0 0 20px',lineHeight:1.4}},'Toca las tarjetas que SÍ son temas de Estudios Sociales'),
    h('div',{style:{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:14,marginBottom:20}},
      ACT1_ITEMS.map((item,i)=>{
        const isSel=selected.has(i);
        let bg=isSel?`${C.purple}22`:C.white;
        let border=isSel?`3px solid ${C.purple}`:'3px solid #e0e0e0';
        if(submitted){
          if(item.correct&&isSel){bg='#d4edda';border=`3px solid ${C.green}`;}
          else if(item.correct&&!isSel){bg='#fff3cd';border=`3px solid ${C.yellow}`;}
          else if(!item.correct&&isSel){bg='#f8d7da';border=`3px solid ${C.red}`;}
          else{bg=C.white;border='3px solid #e0e0e0';}
        }
        return h(Card,{key:i,onClick:()=>toggle(i),style:{border,background:bg,padding:'16px 14px',textAlign:'center'}},
          h('div',{style:{fontSize:32}},item.emoji),
          h('div',{style:{fontSize:16,fontWeight:600,color:C.dark,marginTop:6,lineHeight:1.3}},item.text),
          submitted&&item.correct&&h('div',{style:{fontSize:14,color:C.green,marginTop:4}},CHECK,' Correcto'),
          submitted&&!item.correct&&isSel&&h('div',{style:{fontSize:14,color:C.red,marginTop:4}},WRONG,' No es')
        );
      })
    ),
    !submitted?
      h(Btn,{color:C.purple,onClick:check,big:true,style:{width:'100%'}},'Comprobar mis respuestas'):
      h('div',{style:{textAlign:'center'}},
        h('div',{style:{fontSize:24,marginBottom:12}},STAR.repeat(stars),' ',score,'/',total,' puntos'),
        h(Btn,{color:C.green,onClick:()=>onFinish(stars),big:true,style:{width:'100%'}},'🏠 Volver al menú')
      )
  );
}

/* ───────── ACTIVITY 2 ───────── */
const TIMELINE=[
  {age:"0 años",event:"Nací",emoji:"👶"},
  {age:"1 año",event:"Aprendí a caminar",emoji:"🚶"},
  {age:"3 años",event:"Jugaba en el kinder",emoji:"🎨"},
  {age:"6 años",event:"Entré a primer grado",emoji:"🎒"},
];

function Activity2({onFinish}) {
  const [shuffled]=useState(()=>{
    const arr=TIMELINE.map((t,i)=>({...t,idx:i}));
    for(let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}
    return arr;
  });
  const [matches,setMatches]=useState({});
  const [selectedAge,setSelectedAge]=useState(null);
  const [submitted,setSubmitted]=useState(false);

  const handleEventClick=sIdx=>{if(submitted||selectedAge===null)return;setMatches(p=>({...p,[selectedAge]:sIdx}));setSelectedAge(null);};
  const handleAgeClick=aIdx=>{if(submitted)return;setSelectedAge(aIdx===selectedAge?null:aIdx);};
  const check=()=>setSubmitted(true);

  const score=Object.entries(matches).reduce((acc,[a,s])=>acc+(shuffled[s].idx===Number(a)?1:0),0);
  const stars=score===4?3:score>=3?2:score>=2?1:0;
  const allMatched=Object.keys(matches).length===4;
  const usedEvents=new Set(Object.values(matches));

  return h('div',null,
    h('h2',{style:{fontSize:26,color:C.orange,textAlign:'center',margin:'0 0 8px'}},'👶 Mi Historia Personal'),
    h('p',{style:{fontSize:18,textAlign:'center',color:C.dark,margin:'0 0 20px',lineHeight:1.4}},'Primero toca una edad, luego toca el evento correcto'),
    h('div',{style:{display:'flex',flexDirection:'column',gap:14,marginBottom:20}},
      TIMELINE.map((t,aIdx)=>{
        const mSIdx=matches[aIdx];const mItem=mSIdx!==undefined?shuffled[mSIdx]:null;
        const isSel=selectedAge===aIdx;
        let rc=null;if(submitted&&mItem)rc=mItem.idx===aIdx?C.green:C.red;
        return h('div',{key:aIdx,style:{display:'flex',gap:10,alignItems:'stretch'}},
          h(Card,{onClick:()=>handleAgeClick(aIdx),color:isSel?`${C.orange}33`:C.white,
            style:{flex:'0 0 110px',textAlign:'center',display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',
              border:isSel?`3px solid ${C.orange}`:rc?`3px solid ${rc}`:'3px solid #e0e0e0',padding:'12px 8px'}},
            h('div',{style:{fontSize:16,fontWeight:800,color:C.orange}},t.age)
          ),
          h('div',{style:{flex:'0 0 30px',display:'flex',alignItems:'center',justifyContent:'center',fontSize:28}},'→'),
          h(Card,{color:rc?(rc===C.green?'#d4edda':'#f8d7da'):mItem?`${C.blue}11`:'#f5f5f5',
            style:{flex:1,display:'flex',alignItems:'center',justifyContent:'center',gap:8,
              border:rc?`3px solid ${rc}`:'3px solid #e0e0e0',padding:'12px 10px',minHeight:56}},
            mItem?h('span',{style:{fontSize:16,fontWeight:600}},mItem.emoji,' ',mItem.event):h('span',{style:{fontSize:15,color:C.gray}},'Toca un evento ↓')
          )
        );
      })
    ),
    h('p',{style:{fontSize:16,textAlign:'center',color:C.dark,fontWeight:600,margin:'0 0 10px'}},'Eventos:'),
    h('div',{style:{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:10,marginBottom:20}},
      shuffled.map((item,sIdx)=>{
        const used=usedEvents.has(sIdx);
        return h(Card,{key:sIdx,onClick:()=>!used&&handleEventClick(sIdx),
          color:used?'#e8e8e8':selectedAge!==null?`${C.blue}15`:C.white,
          style:{textAlign:'center',opacity:used?0.5:1,border:selectedAge!==null&&!used?`3px solid ${C.blue}`:'3px solid #e0e0e0',padding:'14px 10px'}},
          h('div',{style:{fontSize:28}},item.emoji),
          h('div',{style:{fontSize:15,fontWeight:600,marginTop:4}},item.event)
        );
      })
    ),
    !submitted?
      h(Btn,{color:C.orange,onClick:check,big:true,disabled:!allMatched,style:{width:'100%'}},
        allMatched?'Comprobar':`Faltan ${4-Object.keys(matches).length} por emparejar`):
      h('div',{style:{textAlign:'center'}},
        h('div',{style:{fontSize:24,marginBottom:12}},STAR.repeat(stars),' ',score,'/4 correctas'),
        h(Btn,{color:C.green,onClick:()=>onFinish(stars),big:true,style:{width:'100%'}},'🏠 Volver al menú')
      )
  );
}

/* ───────── ACTIVITY 3 ───────── */
const SOC_ITEMS=[
  {text:"Cuidar los parques",correct:true,emoji:"🌳"},{text:"Botar basura en la calle",correct:false,emoji:"🗑️"},
  {text:"Participar en deportes",correct:true,emoji:"⚽"},{text:"Destruir zonas verdes",correct:false,emoji:"💥"},
  {text:"Ayudar a los vecinos",correct:true,emoji:"🤗"},{text:"Pelear con los compañeros",correct:false,emoji:"😡"},
  {text:"Respetar a los demás",correct:true,emoji:"💛"},{text:"Ir a la escuela",correct:true,emoji:"🏫"},
];

function Activity3({onFinish}) {
  const [answers,setAnswers]=useState({});
  const [submitted,setSubmitted]=useState(false);
  const answer=(i,v)=>{if(submitted)return;setAnswers(p=>({...p,[i]:v}));};
  const check=()=>setSubmitted(true);
  const score=SOC_ITEMS.reduce((a,item,i)=>a+(answers[i]===item.correct?1:0),0);
  const total=SOC_ITEMS.length;
  const stars=score>=total?3:score>=total-2?2:score>=total-3?1:0;
  const allAnswered=Object.keys(answers).length===total;

  return h('div',null,
    h('h2',{style:{fontSize:26,color:C.green,textAlign:'center',margin:'0 0 8px'}},'🏘️ Vivir en Sociedad'),
    h('p',{style:{fontSize:18,textAlign:'center',color:C.dark,margin:'0 0 20px',lineHeight:1.4}},'¿Esta acción nos ayuda a vivir bien en sociedad?'),
    h('div',{style:{display:'flex',flexDirection:'column',gap:12,marginBottom:20}},
      SOC_ITEMS.map((item,i)=>{
        const ans=answers[i];let bg=C.white,border='3px solid #e0e0e0';
        if(submitted){if(ans===item.correct){bg='#d4edda';border=`3px solid ${C.green}`;}else{bg='#f8d7da';border=`3px solid ${C.red}`;}}
        return h(Card,{key:i,style:{background:bg,border,padding:'14px 16px'}},
          h('div',{style:{display:'flex',alignItems:'center',gap:12,marginBottom:10}},
            h('span',{style:{fontSize:30}},item.emoji),
            h('span',{style:{fontSize:18,fontWeight:600,color:C.dark,flex:1}},item.text)
          ),
          h('div',{style:{display:'flex',gap:10}},
            h('button',{onClick:()=>answer(i,true),style:{flex:1,padding:'10px 0',borderRadius:14,fontSize:17,fontWeight:700,fontFamily:"'Nunito',sans-serif",border:ans===true?`3px solid ${C.green}`:'3px solid #e0e0e0',background:ans===true?`${C.green}22`:C.white,color:C.green,cursor:submitted?'default':'pointer',touchAction:'manipulation'}},'👍 Sí'),
            h('button',{onClick:()=>answer(i,false),style:{flex:1,padding:'10px 0',borderRadius:14,fontSize:17,fontWeight:700,fontFamily:"'Nunito',sans-serif",border:ans===false?`3px solid ${C.red}`:'3px solid #e0e0e0',background:ans===false?`${C.red}22`:C.white,color:C.red,cursor:submitted?'default':'pointer',touchAction:'manipulation'}},'👎 No')
          ),
          submitted&&ans!==item.correct&&h('div',{style:{fontSize:14,color:C.red,marginTop:6,fontWeight:600}},'La respuesta correcta es: ',item.correct?'Sí':'No')
        );
      })
    ),
    !submitted?
      h(Btn,{color:C.green,onClick:check,big:true,disabled:!allAnswered,style:{width:'100%'}},allAnswered?'Comprobar':`Faltan ${total-Object.keys(answers).length}`):
      h('div',{style:{textAlign:'center'}},
        h('div',{style:{fontSize:24,marginBottom:12}},STAR.repeat(stars),' ',score,'/',total,' correctas'),
        h(Btn,{color:C.green,onClick:()=>onFinish(stars),big:true,style:{width:'100%'}},'🏠 Volver al menú')
      )
  );
}

/* ───────── ACTIVITY 4: Family Tree ───────── */
const TREE_Q=[
  {q:"Daniel es el ___ de Sara.",a:"hermano",opts:["hermano","papá","abuelo","tío"],highlight:"Daniel"},
  {q:"Luis es el ___ de Sara.",a:"papá",opts:["hermano","papá","abuelo","primo"],highlight:"Luis"},
  {q:"Carmen es la ___ de Sara.",a:"abuela",opts:["mamá","abuela","tía","hermana"],highlight:"Carmen"},
  {q:"Patricia es la ___ de Sara.",a:"tía",opts:["mamá","abuela","tía","prima"],highlight:"Patricia"},
  {q:"Pedro es el ___ de Sara.",a:"abuelo",opts:["papá","abuelo","tío","hermano"],highlight:"Pedro"},
  {q:"Karol es la ___ de Sara.",a:"mamá",opts:["abuela","mamá","tía","hermana"],highlight:"Karol"},
];

function FamilyTreeSVG({highlight:hl}) {
  const W=520,H=440,R=30,gRow=52,pRow=200,cRow=350;
  const gp={Pedro:80,Marta:200,Oscar:320,Carmen:440};
  const pp={Raul:60,Luis:180,Karol:340,Patricia:460};
  const cp={Daniel:210,Sara:310};
  const members=[
    {key:"Pedro",x:gp.Pedro,y:gRow,emoji:"👴",label:"Pedro",role:"abuelo"},
    {key:"Marta",x:gp.Marta,y:gRow,emoji:"👵",label:"Marta",role:"abuela"},
    {key:"Oscar",x:gp.Oscar,y:gRow,emoji:"👴",label:"Óscar",role:"abuelo"},
    {key:"Carmen",x:gp.Carmen,y:gRow,emoji:"👵",label:"Carmen",role:"abuela"},
    {key:"Raul",x:pp.Raul,y:pRow,emoji:"👨",label:"Raúl",role:"tío"},
    {key:"Luis",x:pp.Luis,y:pRow,emoji:"👨",label:"Luis",role:"papá"},
    {key:"Karol",x:pp.Karol,y:pRow,emoji:"👩",label:"Karol",role:"mamá"},
    {key:"Patricia",x:pp.Patricia,y:pRow,emoji:"👩",label:"Patricia",role:"tía"},
    {key:"Daniel",x:cp.Daniel,y:cRow,emoji:"👦",label:"Daniel",role:"hermano"},
    {key:"Sara",x:cp.Sara,y:cRow,emoji:"👧",label:"Sara",role:"yo ⭐"},
  ];
  const ln=(p)=>h('line',{...p,stroke:'#A8CCE8',strokeWidth:3,strokeLinecap:'round'});
  const gpMidL=(gp.Pedro+gp.Marta)/2,gpMidR=(gp.Oscar+gp.Carmen)/2;
  const gpBotY=gRow+R+6,busY1=gRow+R+30,pTopY=pRow-R-22;
  const ppMid=(pp.Luis+pp.Karol)/2,ppBotY=pRow+R+6,busY2=pRow+R+30,cTopY=cRow-R-22;

  return h('svg',{viewBox:`0 0 ${W} ${H}`,style:{width:'100%',height:'auto',display:'block'}},
    h('rect',{x:0,y:0,width:W,height:H,rx:22,fill:'#EEF5FF'}),
    h('text',{x:10,y:gRow+4,fontSize:10,fill:'#9BB8D3',fontFamily:'Nunito,sans-serif',fontWeight:700},'Abuelos'),
    h('text',{x:10,y:pRow+4,fontSize:10,fill:'#9BB8D3',fontFamily:'Nunito,sans-serif',fontWeight:700},'Padres'),
    h('text',{x:10,y:cRow+4,fontSize:10,fill:'#9BB8D3',fontFamily:'Nunito,sans-serif',fontWeight:700},'Hijos'),
    // Lines
    ln({key:'l1',x1:gp.Pedro,y1:gpBotY,x2:gp.Marta,y2:gpBotY}),ln({key:'l2',x1:gpMidL,y1:gpBotY,x2:gpMidL,y2:busY1}),
    ln({key:'l3',x1:pp.Raul,y1:busY1,x2:pp.Luis,y2:busY1}),ln({key:'l4',x1:pp.Raul,y1:busY1,x2:pp.Raul,y2:pTopY}),ln({key:'l5',x1:pp.Luis,y1:busY1,x2:pp.Luis,y2:pTopY}),
    ln({key:'l6',x1:gp.Oscar,y1:gpBotY,x2:gp.Carmen,y2:gpBotY}),ln({key:'l7',x1:gpMidR,y1:gpBotY,x2:gpMidR,y2:busY1}),
    ln({key:'l8',x1:pp.Karol,y1:busY1,x2:pp.Patricia,y2:busY1}),ln({key:'l9',x1:pp.Karol,y1:busY1,x2:pp.Karol,y2:pTopY}),ln({key:'l10',x1:pp.Patricia,y1:busY1,x2:pp.Patricia,y2:pTopY}),
    ln({key:'l11',x1:pp.Luis,y1:ppBotY,x2:pp.Karol,y2:ppBotY}),ln({key:'l12',x1:ppMid,y1:ppBotY,x2:ppMid,y2:busY2}),
    ln({key:'l13',x1:cp.Daniel,y1:busY2,x2:cp.Sara,y2:busY2}),ln({key:'l14',x1:cp.Daniel,y1:busY2,x2:cp.Daniel,y2:cTopY}),ln({key:'l15',x1:cp.Sara,y1:busY2,x2:cp.Sara,y2:cTopY}),
    // Hearts
    h('text',{key:'h1',x:gpMidL,y:gpBotY-2,textAnchor:'middle',fontSize:13},'❤️'),
    h('text',{key:'h2',x:gpMidR,y:gpBotY-2,textAnchor:'middle',fontSize:13},'❤️'),
    h('text',{key:'h3',x:ppMid,y:ppBotY-2,textAnchor:'middle',fontSize:13},'❤️'),
    // Members
    ...members.map(m=>{
      const isH=hl===m.key,isS=m.key==='Sara';
      return h('g',{key:m.key},
        isH&&h('circle',{cx:m.x,cy:m.y,r:R+8,fill:'none',stroke:C.orange,strokeWidth:4,strokeDasharray:'8 4',opacity:0.85},
          h('animateTransform',{attributeName:'transform',type:'rotate',from:`0 ${m.x} ${m.y}`,to:`360 ${m.x} ${m.y}`,dur:'3s',repeatCount:'indefinite'})
        ),
        h('circle',{cx:m.x,cy:m.y,r:R,fill:isS?'#FFF3E0':isH?'#FFFDE7':'#FFF',stroke:isS?C.orange:isH?C.orange:'#C0D8ED',strokeWidth:isS||isH?3.5:2.5}),
        h('text',{x:m.x,y:m.y+10,textAnchor:'middle',fontSize:30},m.emoji),
        h('rect',{x:m.x-38,y:m.y+R+6,width:76,height:22,rx:11,fill:isS?C.orange:isH?C.blue:'#D4E5F5'}),
        h('text',{x:m.x,y:m.y+R+21,textAnchor:'middle',fontSize:12,fontWeight:800,fill:isS||isH?'#FFF':'#3B6F96',fontFamily:'Nunito,sans-serif'},m.label),
        h('text',{x:m.x,y:m.y+R+38,textAnchor:'middle',fontSize:10,fontWeight:600,fill:'#8FAFC4',fontFamily:'Nunito,sans-serif'},m.role)
      );
    }),
    h('text',{x:W/2,y:H-8,textAnchor:'middle',fontSize:11,fill:'#9BB8D3',fontFamily:'Nunito,sans-serif',fontWeight:600},'🌳 La familia de Sara')
  );
}

function Activity4({onFinish}) {
  const [current,setCurrent]=useState(0);
  const [answers,setAnswers]=useState([]);
  const [selected,setSelected]=useState(null);
  const [showFeedback,setShowFeedback]=useState(false);

  const handleSelect=opt=>{
    if(showFeedback)return;setSelected(opt);setShowFeedback(true);
    setAnswers(p=>[...p,opt===TREE_Q[current].a]);
    setTimeout(()=>{setShowFeedback(false);setSelected(null);setCurrent(c=>c+1);},1200);
  };

  if(current>=TREE_Q.length){
    const score=answers.filter(Boolean).length;
    const stars=score>=6?3:score>=4?2:score>=2?1:0;
    return h('div',{style:{textAlign:'center'}},
      h('h2',{style:{fontSize:26,color:C.blue,margin:'0 0 16px'}},'🌳 Árbol Genealógico'),
      h('div',{style:{fontSize:60,marginBottom:12}},'🌳'),
      h('div',{style:{fontSize:24,marginBottom:8}},STAR.repeat(stars),' ',score,'/',TREE_Q.length,' correctas'),
      h('p',{style:{fontSize:18,color:C.dark,marginBottom:20}},score>=5?'¡Conocés muy bien a la familia!':score>=3?'¡Buen trabajo!':'¡Seguí practicando!'),
      h(Btn,{color:C.green,onClick:()=>onFinish(stars),big:true,style:{width:'100%'}},'🏠 Volver al menú')
    );
  }
  const q=TREE_Q[current];
  return h('div',null,
    h('h2',{style:{fontSize:26,color:C.blue,textAlign:'center',margin:'0 0 8px'}},'🌳 Árbol Genealógico'),
    h(ProgressBar,{current,total:TREE_Q.length,color:C.blue}),
    h('div',{style:{margin:'14px -4px 18px',borderRadius:22,overflow:'hidden',boxShadow:C.shadowSm}},h(FamilyTreeSVG,{highlight:q.highlight})),
    h(Card,{style:{background:`${C.blue}11`,border:`3px solid ${C.blue}`,marginBottom:18,textAlign:'center'}},
      h('div',{style:{fontSize:17,fontWeight:700,color:C.dark}},'Pregunta ',current+1,' de ',TREE_Q.length),
      h('div',{style:{fontSize:22,fontWeight:700,color:C.blue,marginTop:6}},q.q)
    ),
    h('div',{style:{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:12,marginBottom:16}},
      q.opts.map(opt=>{
        let bg=C.white,border='3px solid #e0e0e0';
        if(showFeedback&&selected===opt){bg=opt===q.a?'#d4edda':'#f8d7da';border=`3px solid ${opt===q.a?C.green:C.red}`;}
        else if(showFeedback&&opt===q.a){bg='#d4edda';border=`3px solid ${C.green}`;}
        return h(Card,{key:opt,onClick:()=>handleSelect(opt),style:{background:bg,border,textAlign:'center',padding:'18px 12px'}},
          h('span',{style:{fontSize:20,fontWeight:700,color:C.dark}},opt)
        );
      })
    ),
    showFeedback&&h(FeedbackBubble,{correct:selected===q.a,message:selected===q.a?'¡Correcto!':`Era: ${q.a}`})
  );
}

/* ───────── ACTIVITY 5 ───────── */
const DD_ITEMS=[
  {text:"Vivir en una casa segura",type:"derecho",emoji:"🏠"},{text:"Lavar los platos",type:"deber",emoji:"🍽️"},
  {text:"Recibir atención médica",type:"derecho",emoji:"🏥"},{text:"Ser tratados con respeto",type:"derecho",emoji:"💖"},
  {text:"Ordenar y limpiar el cuarto",type:"deber",emoji:"🧹"},{text:"Respetar a las personas",type:"deber",emoji:"🙏"},
  {text:"Tener una casa",type:"derecho",emoji:"🏡"},{text:"Recoger los zapatos",type:"deber",emoji:"👟"},
  {text:"Hacer las tareas escolares",type:"deber",emoji:"📝"},{text:"Ir a la escuela",type:"deber",emoji:"🎒"},
];

function Activity5({onFinish}) {
  const [answers,setAnswers]=useState({});
  const [submitted,setSubmitted]=useState(false);
  const answer=(i,v)=>{if(submitted)return;setAnswers(p=>({...p,[i]:v}));};
  const check=()=>setSubmitted(true);
  const score=DD_ITEMS.reduce((a,item,i)=>a+(answers[i]===item.type?1:0),0);
  const total=DD_ITEMS.length;
  const stars=score>=total?3:score>=total-2?2:score>=total-4?1:0;
  const allAnswered=Object.keys(answers).length===total;

  return h('div',null,
    h('h2',{style:{fontSize:26,color:C.pink,textAlign:'center',margin:'0 0 8px'}},'⚖️ Derechos y Deberes'),
    h('p',{style:{fontSize:18,textAlign:'center',color:C.dark,margin:'0 0 10px',lineHeight:1.4}},'¿Es un derecho o un deber?'),
    h('div',{style:{display:'flex',gap:10,justifyContent:'center',marginBottom:16,flexWrap:'wrap'}},
      h('span',{style:{fontSize:14,fontWeight:700,color:C.blue,background:`${C.blue}22`,padding:'6px 14px',borderRadius:12}},'🛡️ Derecho = lo que merecés'),
      h('span',{style:{fontSize:14,fontWeight:700,color:C.orange,background:`${C.orange}22`,padding:'6px 14px',borderRadius:12}},'✋ Deber = lo que debés hacer')
    ),
    h('div',{style:{display:'flex',flexDirection:'column',gap:10,marginBottom:20}},
      DD_ITEMS.map((item,i)=>{
        const ans=answers[i];let bg=C.white,border='3px solid #e0e0e0';
        if(submitted){if(ans===item.type){bg='#d4edda';border=`3px solid ${C.green}`;}else{bg='#f8d7da';border=`3px solid ${C.red}`;}}
        return h(Card,{key:i,style:{background:bg,border,padding:'12px 14px'}},
          h('div',{style:{display:'flex',alignItems:'center',gap:10,marginBottom:8}},
            h('span',{style:{fontSize:26}},item.emoji),h('span',{style:{fontSize:17,fontWeight:600,color:C.dark,flex:1}},item.text)
          ),
          h('div',{style:{display:'flex',gap:8}},
            h('button',{onClick:()=>answer(i,'derecho'),style:{flex:1,padding:'10px 0',borderRadius:14,fontSize:16,fontWeight:700,fontFamily:"'Nunito',sans-serif",border:ans==='derecho'?`3px solid ${C.blue}`:'3px solid #e0e0e0',background:ans==='derecho'?`${C.blue}22`:C.white,color:C.blue,cursor:submitted?'default':'pointer',touchAction:'manipulation'}},'🛡️ Derecho'),
            h('button',{onClick:()=>answer(i,'deber'),style:{flex:1,padding:'10px 0',borderRadius:14,fontSize:16,fontWeight:700,fontFamily:"'Nunito',sans-serif",border:ans==='deber'?`3px solid ${C.orange}`:'3px solid #e0e0e0',background:ans==='deber'?`${C.orange}22`:C.white,color:C.orange,cursor:submitted?'default':'pointer',touchAction:'manipulation'}},'✋ Deber')
          ),
          submitted&&ans!==item.type&&h('div',{style:{fontSize:14,color:C.red,marginTop:4,fontWeight:600}},'Es un ',item.type==='derecho'?'🛡️ Derecho':'✋ Deber')
        );
      })
    ),
    !submitted?
      h(Btn,{color:C.pink,onClick:check,big:true,disabled:!allAnswered,style:{width:'100%'}},allAnswered?'Comprobar':`Faltan ${total-Object.keys(answers).length}`):
      h('div',{style:{textAlign:'center'}},
        h('div',{style:{fontSize:24,marginBottom:12}},STAR.repeat(stars),' ',score,'/',total,' correctas'),
        h(Btn,{color:C.green,onClick:()=>onFinish(stars),big:true,style:{width:'100%'}},'🏠 Volver al menú')
      )
  );
}

/* ───────── MENU ───────── */
function MenuScreen({scores,onSelect,onReset}) {
  const totalStars=scores.reduce((a,b)=>a+b,0);
  const maxStars=scores.length*3;
  const allPerfect=totalStars===maxStars;

  return h('div',{style:{padding:'12px 0'}},
    h('div',{style:{textAlign:'center',marginBottom:20}},
      h('div',{style:{fontSize:64,marginBottom:4,animation:'float 3s ease-in-out infinite'}},'📚'),
      h('h1',{style:{fontSize:30,fontWeight:900,color:C.purple,margin:'0 0 4px',fontFamily:"'Nunito',sans-serif"}},'Estudios Sociales'),
      h('p',{style:{fontSize:17,color:C.dark,margin:0,fontWeight:600}},'Primer Grado — ¡Elegí un juego!')
    ),
    totalStars>0&&h('div',{style:{background:C.white,borderRadius:20,padding:'14px 18px',marginBottom:20,boxShadow:C.shadowSm,display:'flex',alignItems:'center',gap:12}},
      h('div',{style:{flex:1}},
        h('div',{style:{fontSize:13,color:C.gray,fontWeight:600,marginBottom:4}},'Tu progreso total'),
        h(ProgressBar,{current:totalStars,total:maxStars,color:C.purple})
      ),
      h('div',{style:{fontSize:18,fontWeight:800,color:C.dark,flexShrink:0}},totalStars,'/',maxStars,' ',STAR)
    ),
    allPerfect&&h('div',{style:{background:'linear-gradient(135deg,#FFD93D33,#6BCB7733)',borderRadius:20,padding:'16px 20px',marginBottom:20,textAlign:'center',border:`3px solid ${C.yellow}`}},
      h('div',{style:{fontSize:36}},'🏆'),
      h('div',{style:{fontSize:18,fontWeight:800,color:C.dark}},'¡Perfecto! ¡Todas las estrellas!')
    ),
    h('div',{style:{display:'flex',flexDirection:'column',gap:14,marginBottom:24}},
      ACTIVITIES.map((act,i)=>{
        const played=scores[i]>0;
        return h(Card,{key:i,onClick:()=>onSelect(i),style:{display:'flex',alignItems:'center',gap:14,padding:'18px 20px',border:`3px solid ${played?act.color:act.color+'44'}`,background:played?`${act.color}08`:C.white,position:'relative',overflow:'hidden'}},
          h('div',{style:{position:'absolute',left:0,top:0,bottom:0,width:6,background:act.color,borderRadius:'24px 0 0 24px'}}),
          h('div',{style:{width:56,height:56,borderRadius:16,background:`${act.color}18`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:30,flexShrink:0}},act.emoji),
          h('div',{style:{flex:1,minWidth:0}},
            h('div',{style:{fontSize:19,fontWeight:800,color:C.dark,marginBottom:2}},act.name),
            h('div',{style:{fontSize:14,color:C.gray,fontWeight:500}},act.desc),
            played&&h('div',{style:{marginTop:4}},h(StarsDisplay,{count:scores[i]}))
          ),
          h('div',{style:{width:44,height:44,borderRadius:14,background:played?act.color:`${act.color}22`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:20,flexShrink:0,color:played?C.white:act.color,fontWeight:800}},played?'🔄':'▶')
        );
      })
    ),
    totalStars>0&&h('button',{onClick:onReset,style:{width:'100%',padding:'14px 0',borderRadius:18,border:`2px solid ${C.gray}44`,background:'transparent',fontSize:16,fontWeight:700,color:C.gray,fontFamily:"'Nunito',sans-serif",cursor:'pointer',touchAction:'manipulation'}},'🗑️ Reiniciar todos los puntajes')
  );
}

/* ───────── Confirm Modal ───────── */
function ConfirmModal({title,message,emoji,onConfirm,onCancel}) {
  return h('div',{style:{position:'fixed',inset:0,background:'rgba(0,0,0,0.45)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:2000,padding:24}},
    h('div',{style:{background:C.white,borderRadius:28,padding:'32px 28px',maxWidth:380,width:'100%',textAlign:'center',boxShadow:C.shadow,animation:'popIn 0.25s ease'}},
      h('div',{style:{fontSize:52,marginBottom:12}},emoji),
      h('h3',{style:{fontSize:22,color:C.dark,margin:'0 0 8px',fontFamily:"'Nunito',sans-serif"}},title),
      h('p',{style:{fontSize:16,color:C.gray,margin:'0 0 24px',lineHeight:1.4}},message),
      h('div',{style:{display:'flex',gap:12}},
        h(Btn,{color:C.gray,onClick:onCancel,style:{flex:1,fontSize:17}},'Cancelar'),
        h(Btn,{color:C.red,onClick:onConfirm,style:{flex:1,fontSize:17}},'Sí')
      )
    )
  );
}

/* ───────── Install Banner ───────── */
function InstallBanner({onInstall,onDismiss}) {
  return h('div',{className:'install-banner'},
    h('div',{style:{fontSize:40}},'📚'),
    h('div',{style:{flex:1}},
      h('div',{style:{fontSize:16,fontWeight:800,color:C.dark}},'Instalar en tu tablet'),
      h('div',{style:{fontSize:13,color:C.gray}},'Jugá sin internet')
    ),
    h(Btn,{color:C.purple,onClick:onInstall,style:{fontSize:15,padding:'10px 18px',minHeight:42}},'Instalar'),
    h('button',{onClick:onDismiss,style:{border:'none',background:'none',fontSize:20,cursor:'pointer',padding:8,color:C.gray}},'✕')
  );
}

/* ───────── MAIN APP ───────── */
function App() {
  const [screen,setScreen]=useState('menu');
  const [scores,setScores]=useState(()=>Storage.get('es_scores',[0,0,0,0,0]));
  const [showBurst,setShowBurst]=useState(false);
  const [modal,setModal]=useState(null);
  const [actKey,setActKey]=useState(0);
  const [showInstall,setShowInstall]=useState(false);
  const containerRef=useRef(null);

  // Persist scores
  useEffect(()=>{Storage.set('es_scores',scores);},[scores]);

  // Install prompt
  useEffect(()=>{
    window.__showInstallBanner=()=>setShowInstall(true);
    return ()=>{window.__showInstallBanner=null;};
  },[]);

  const goHome=useCallback(()=>{setScreen('menu');setModal(null);if(containerRef.current)containerRef.current.scrollTop=0;},[]);

  const handleFinish=useCallback((actIdx,stars)=>{
    setScores(p=>{const n=[...p];n[actIdx]=Math.max(n[actIdx],stars);return n;});
    if(stars===3){setShowBurst(true);setTimeout(()=>setShowBurst(false),1500);}
    setScreen('menu');
    if(containerRef.current)containerRef.current.scrollTop=0;
  },[]);

  const selectActivity=i=>{setActKey(k=>k+1);setScreen(i);if(containerRef.current)containerRef.current.scrollTop=0;};
  const resetAll=()=>{setScores([0,0,0,0,0]);setModal(null);};

  const handleInstall=async()=>{
    if(deferredPrompt){
      deferredPrompt.prompt();
      const result=await deferredPrompt.userChoice;
      deferredPrompt=null;
    }
    setShowInstall(false);
  };

  const showingActivity=typeof screen==='number';

  return h(Fragment,null,
    h('div',{ref:containerRef,style:{maxWidth:540,margin:'0 auto',padding:'20px 16px 40px',minHeight:'100vh',fontFamily:"'Nunito',sans-serif",position:'relative'}},
      showingActivity&&h('div',{style:{display:'flex',alignItems:'center',gap:10,marginBottom:16,padding:'10px 14px',background:C.white,borderRadius:18,boxShadow:C.shadowSm}},
        h('button',{onClick:()=>setModal('home'),style:{width:44,height:44,borderRadius:14,border:`2px solid ${C.red}44`,background:`${C.red}12`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:22,cursor:'pointer',touchAction:'manipulation',flexShrink:0}},'🏠'),
        h('div',{style:{flex:1}},
          h('div',{style:{fontSize:15,fontWeight:700,color:ACTIVITIES[screen].color}},ACTIVITIES[screen].emoji,' ',ACTIVITIES[screen].name)
        ),
        h('div',{style:{fontSize:14,fontWeight:700,color:C.dark,flexShrink:0,background:`${C.yellow}33`,padding:'6px 12px',borderRadius:12}},'Mejor: ',scores[screen]>0?STAR.repeat(scores[screen]):'—')
      ),
      screen==='menu'&&h(MenuScreen,{scores,onSelect:selectActivity,onReset:()=>setModal('reset')}),
      screen===0&&h(Activity1,{key:'a1-'+actKey,onFinish:s=>handleFinish(0,s)}),
      screen===1&&h(Activity2,{key:'a2-'+actKey,onFinish:s=>handleFinish(1,s)}),
      screen===2&&h(Activity3,{key:'a3-'+actKey,onFinish:s=>handleFinish(2,s)}),
      screen===3&&h(Activity4,{key:'a4-'+actKey,onFinish:s=>handleFinish(3,s)}),
      screen===4&&h(Activity5,{key:'a5-'+actKey,onFinish:s=>handleFinish(4,s)})
    ),
    h(StarBurst,{show:showBurst}),
    modal==='home'&&h(ConfirmModal,{emoji:'🏠',title:'¿Volver al menú?',message:'Si salís ahora, no se guardará el progreso de este juego.',onConfirm:goHome,onCancel:()=>setModal(null)}),
    modal==='reset'&&h(ConfirmModal,{emoji:'🗑️',title:'¿Reiniciar todo?',message:'Se borrarán todas las estrellas ganadas en todos los juegos.',onConfirm:resetAll,onCancel:()=>setModal(null)}),
    showInstall&&h(InstallBanner,{onInstall:handleInstall,onDismiss:()=>setShowInstall(false)})
  );
}

// ─── Mount ───
const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(h(App));

// Hide splash
setTimeout(() => {
  const splash = document.getElementById('splash');
  if (splash) { splash.classList.add('hide'); setTimeout(() => splash.remove(), 500); }
}, 800);
</script>
</body>
</html>
